# URL of the target frontend/backend — primary target is the shared Railway dev
# environment (same one manual testers use). Ask for the current Railway URLs,
# or reuse the values already configured as GitHub Actions secrets for e2e.yml.
# Su Railway: https://<frontend-dev>.up.railway.app
BASE_URL=https://<frontend-dev>.up.railway.app

# In locale (solo se disponibile un frontend locale su vite --port=3000):
# BASE_URL=http://localhost:3000

# URL del backend (usato per le chiamate API dirette nei test RBAC e per gli
# endpoint di test in e2e/fixtures/testAdmin.ts)
# Su Railway: https://<backend-dev>.up.railway.app
API_BASE_URL=https://<backend-dev>.up.railway.app
# In locale: API_BASE_URL=http://localhost:4000

# Dev-login credentials (must match backend ENABLE_DEV_LOGIN vars)
DEV_LOGIN_USER=dev@dblue.it
DEV_LOGIN_PASS=changeme

# Second user with employee role for RBAC tests — must be a real backend
# DEV_ACCOUNTS entry (backend/src/routes/auth.routes.ts), not a placeholder.
DEV_LOGIN_EMPLOYEE_USER=mario.rossi@dblue.it
DEV_LOGIN_EMPLOYEE_PASS=changeme
