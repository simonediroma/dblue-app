# URL of the running frontend
# In locale: http://localhost:5173
# Su Railway: https://<tuo-frontend>.up.railway.app
BASE_URL=http://localhost:5173

# URL del backend (usato per le chiamate API dirette nei test RBAC)
# In locale: http://localhost:4000
# Su Railway: https://<tuo-backend>.up.railway.app
API_BASE_URL=http://localhost:4000

# Dev-login credentials (must match backend ENABLE_DEV_LOGIN vars)
DEV_LOGIN_USER=dev@dblue.it
DEV_LOGIN_PASS=changeme

# Optional: second user with employee role for RBAC tests
DEV_LOGIN_EMPLOYEE_USER=employee@dblue.it
DEV_LOGIN_EMPLOYEE_PASS=changeme
